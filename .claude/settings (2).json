{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_doc": "Project-scoped settings for breakthrough/. Hooks here apply only when working in this directory.",
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/script_run_gate.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/stop_deep_review_gate.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/stop_deep_review_gate.py"
          }
        ]
      }
    ]
  }
}
